PORT=8080
HOST=127.0.0.1

# Required for any non-local bind such as HOST=0.0.0.0.
ADMIN_TOKEN=change-this-for-remote-admin
API_TOKEN=change-this-for-remote-api

# Comma-separated exact origins for remote/static dashboards.
# Localhost origins are allowed by the default CORS_ORIGIN_REGEX.
CORS_ORIGINS=
CORS_ORIGIN_REGEX=^https?://(localhost|127\.0\.0\.1|\[::1\])(:\d+)?$

# Per client/token/path. Set to 0 only for trusted local-only testing.
RATE_LIMIT_PER_MINUTE=120

# Number of recent sanitized diagnostic events kept in memory.
DIAGNOSTIC_EVENT_LIMIT=200

# Set DEBUG_ERRORS=1 only while debugging packaging issues locally.
DEBUG_ERRORS=0
